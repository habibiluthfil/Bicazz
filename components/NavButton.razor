@namespace Bicazz.Components
@* Komponen NavButton menampilkan tombol navigasi yang dapat digunakan di header dan mobile.
   Fungsi: Menyajikan ikon dan teks tombol, dengan gaya berbeda untuk state aktif dan mobile. *@

<button class="nav-button @(Active ? "active" : "") @(Mobile ? "mobile" : "")" @onclick="OnClick">
    <span class="icon">@Icon</span>
    @if (!Mobile)
    {
        <span>@Text</span>
    }
</button>

@code {
    [Parameter]
    public RenderFragment Icon { get; set; } = default!;

    [Parameter]
    public string Text { get; set; } = string.Empty;

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public bool Mobile { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }
}
