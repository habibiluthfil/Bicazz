@namespace Bicazz.Components
@* Komponen Card adalah wrapper UI generik untuk semua konten kartu.
   Fungsi: Menyediakan styling konsisten untuk section konten di seluruh aplikasi. *@

<div class="card @AdditionalClass">
    @ChildContent
</div>

@code {
    [Parameter]
    public string AdditionalClass { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
