@namespace Bicazz.Features
@using Bicazz.Data

@* TabunganFeature menampilkan UI untuk membuat dan memantau target tabungan.
   Fungsi: Menyediakan form pembuatan goal baru, status progress, dan input saldo tambahan. *@

<div class="grid-two" style="gap: 1.5rem; align-items:start;">
    <Card>
        <h3>Buat Target Baru</h3>
        <form @onsubmit="CreateGoal">
            <div>
                <label>Nama Target</label>
                <input type="text" @bind="name" placeholder="Contoh: Beli Laptop" required />
            </div>
            <div>
                <label>Jumlah Target (Rp)</label>
                <input type="number" @bind="target" placeholder="Contoh: 10000000" required />
            </div>
            <button type="submit" class="btn-secondary" style="width:100%; margin-top: 1rem;">Mulai Menabung</button>
        </form>
    </Card>

    <div style="display:flex; flex-direction:column; gap:1rem;">
        @if (!goals.Any())
        {
            <Card style="text-align:center; opacity:0.75;">
                <div style="font-size:2rem;">🎯</div>
                <p>Belum ada target tabungan.</p>
            </Card>
        }
        @foreach (var goal in goals)
        {
            var percentage = goal.Target == 0 ? 0 : Math.Min(100, (int)Math.Round(goal.Current / goal.Target * 100));
            var isComplete = goal.Current >= goal.Target;
            <Card style="@(isComplete ? "border:2px solid #22c55e;" : "border:1px solid rgba(255,255,255,0.45);")">
                <h4>@goal.Name @if (isComplete) { <span>🎉</span> }</h4>
                <p style="opacity:0.75; margin-bottom: 1rem;">Target: Rp @goal.Target.ToString("N0")</p>
                <div class="progress-bar">
                    <div class="progress-fill" style="width:@percentage%@; background:@(isComplete ? "linear-gradient(90deg, #22c55e, #10b981)" : "linear-gradient(90deg, #f97316, #ef4444)")">
                        @if (percentage > 10) { <span>@percentage%@</span> }
                    </div>
                </div>
                <div style="display:flex; justify-content:space-between; margin:1rem 0; font-weight:700;">Terkumpul: Rp @goal.Current.ToString("N0")</div>
                @if (!isComplete)
                {
                    @if (activeEditId == goal.Id)
                    {
                        <form @onsubmit="() => AddProgress(goal.Id)">
                            <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
                                <input type="number" @bind="progressAmount" placeholder="Nominal..." required style="flex:1;" />
                                <button type="submit" class="btn-secondary">Simpan</button>
                                <button type="button" class="btn-tertiary" @onclick="CancelEdit">Batal</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <button class="btn-secondary" style="width:100%;" @onclick="() => StartEdit(goal.Id)">Tambah Saldo</button>
                    }
                }
                else
                {
                    <div style="padding:1rem; border-radius:1rem; background:#dcfce7; color:#166534; text-align:center;">Target Terpenuhi!</div>
                }
            </Card>
        }
    </div>
</div>
