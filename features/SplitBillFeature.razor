@namespace Bicazz.Features

@* SplitBillFeature menampilkan UI untuk menghitung pembagian tagihan.
   Fungsi: Mengumpulkan input tagihan dan jumlah orang, kemudian menampilkan hasil pembagian per orang. *@

<div class="max-w-2xl" style="margin:0 auto;">
    <Card>
        <div style="text-align:center; margin-bottom: 1.5rem;">
            <div style="display:inline-flex; align-items:center; justify-content:center; width:4rem; height:4rem; border-radius:2rem; background:rgba(59,130,246,0.15); color:#2563eb; margin-bottom:1rem; font-size:1.75rem;">🧮</div>
            <h3>Split Bill</h3>
        </div>
        <div style="margin-bottom:1rem;">
            <label>Total Tagihan (Rp)</label>
            <input type="number" @bind="mainBill" placeholder="0" />
        </div>
        <div style="margin-bottom:1.5rem;">
            <label>Jumlah Orang: @people</label>
            <input type="range" min="1" max="20" @bind="people" />
        </div>
        @if (result is null)
        {
            <button class="btn-tertiary" style="width:100%;" @onclick="Calculate">Hitung</button>
        }
        else
        {
            <div style="padding:1.5rem; border-radius:1.75rem; background:rgba(59,130,246,0.1); text-align:center;">
                <p style="opacity:0.75; margin:0;">Masing-masing bayar:</p>
                <h4 style="margin:1rem 0 0; color:#1d4ed8;">Rp @Math.Round(result.Value.PerPerson).ToString("N0")</h4>
                <button class="btn-secondary" style="margin-top:1rem;" @onclick="Reset">Reset</button>
            </div>
        }
    </Card>
</div>
