@namespace Bicazz.Shared
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

@* MainLayout menyediakan struktur halaman utama.
   Fungsi: Menampilkan header, navigasi, konten dinamis, dan footer.
   Logika dark mode dipisah ke file code-behind untuk menjaga markup tetap bersih. *@
<div class="app-root @(darkMode ? "dark" : "")">
    <div class="background"></div>
    <div class="page-wrapper">
        <nav class="top-nav">
            <div class="brand" @onclick="() => NavigationManager.NavigateTo('/')">
                <img src="@AppConstants.LogoUrl" alt="Bicazz Logo" onerror="this.src='https://via.placeholder.com/150?text=BZ'" />
                <span>Bicazz</span>
            </div>
            <div class="nav-actions">
                <div class="nav-links">
                    <NavLink href="/" class="nav-link" activeclassname="active" Match="NavLinkMatch.All">Home</NavLink>
                    <NavLink href="/design" class="nav-link" activeclassname="active">Design</NavLink>
                    <NavLink href="/product" class="nav-link" activeclassname="active">Product</NavLink>
                </div>
                <button class="theme-toggle" @onclick="ToggleDarkMode" title="Toggle Dark Mode">
                    @(darkMode ? "☀️" : "🌙")
                </button>
            </div>
        </nav>

        <div class="mobile-nav">
            <NavLink href="/" class="nav-button" activeclassname="active" Match="NavLinkMatch.All">🏠</NavLink>
            <NavLink href="/design" class="nav-button" activeclassname="active">🖊️</NavLink>
            <NavLink href="/product" class="nav-button" activeclassname="active">📦</NavLink>
        </div>

        <main class="main-content">
            @Body
        </main>

        <footer class="footer">
            Project by <strong>THE-lNCREDIBLES</strong> © 2026
        </footer>
    </div>
</div>
